# Display name shown in the Kocity server list.
SERVER_NAME=My Game Server

# Central Auth API. No trailing slash.
AUTH_SERVER=https://api.kocity.cc

# Public host:port players use to reach this game server.
PUBLIC_ADDRESS=203.0.113.10:23600
MAX_PLAYERS=50

# Port the proxy listens on. Set this to the public TCP port unless you forward ports separately.
EXTERNAL_PORT=23600

# Internal game engine target.
INTERNAL_HOST=127.0.0.1
INTERNAL_PORT=23600

# Redis used by the local game server/proxy.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Local game database.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/gamedb?schema=public

# Shared secret used for server heartbeats. Must match the server record in Auth/Directus.
SERVER_SECRET=change-me
